\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces \textbf  {Full results across all four validation strands for the 13 priority clusters and 3 null clusters.} KL ratio: cross/same symmetric KL divergence ratio. Bary wins: fraction of top-50 tokens where $R^2_{\mathrm  {bary}} > R^2_{\mathrm  {best\,latent}}$ (``sig.'' if Wilcoxon $p < 0.001$). Steering: best-combination steering score (``---'' if cluster did not qualify). Interp.: consistency of frontier-LLM vertex labels across 20 iterations (HIGH/MED/LOW). \relax }}{12}{table.caption.36}\protected@file@percent }
\newlabel{tab:full_results}{{5}{12}{\textbf {Full results across all four validation strands for the 13 priority clusters and 3 null clusters.} KL ratio: cross/same symmetric KL divergence ratio. Bary wins: fraction of top-50 tokens where $R^2_{\mathrm {bary}} > R^2_{\mathrm {best\,latent}}$ (``sig.'' if Wilcoxon $p < 0.001$). Steering: best-combination steering score (``---'' if cluster did not qualify). Interp.: consistency of frontier-LLM vertex labels across 20 iterations (HIGH/MED/LOW). \relax }{table.caption.36}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Simplex structure in the toy model residual stream (layer 2).} Each point is a token position from a held-out sequence. Colors encode the true belief state: RGB channels are proportional to the probability assigned to each of the three hidden states of the Mess3 component (pure red, green, blue at the vertices; mixed colors in the interior). \emph  {Top row:} ground-truth belief states. \emph  {Bottom row:} belief states predicted by linear readout from the layer-2 residual stream. The triangular (2-simplex) structure of the Mess3 components and the circular (1-simplex product) structure of the Tom Quantum components are clearly visible, confirming that the transformer has learned to represent these belief geometries. \relax }}{13}{figure.caption.6}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:toy_pca}{{1}{13}{\textbf {Simplex structure in the toy model residual stream (layer 2).} Each point is a token position from a held-out sequence. Colors encode the true belief state: RGB channels are proportional to the probability assigned to each of the three hidden states of the Mess3 component (pure red, green, blue at the vertices; mixed colors in the interior). \emph {Top row:} ground-truth belief states. \emph {Bottom row:} belief states predicted by linear readout from the layer-2 residual stream. The triangular (2-simplex) structure of the Mess3 components and the circular (1-simplex product) structure of the Tom Quantum components are clearly visible, confirming that the transformer has learned to represent these belief geometries. \relax }{figure.caption.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Per-latent activation profiles for the toy model (layer 2, TopK $K=3$).} Each panel shows the activation of a single SAE latent as a function of the ground-truth belief state (heatmap over Mess3 $(x, a)$ parameter space). Latents are sorted by total activation weight. Individual latents fire preferentially near specific vertices or edges of the belief simplex, tiling the simplex geometry in a graded, partially overlapping fashion. \relax }}{14}{figure.caption.7}\protected@file@percent }
\newlabel{fig:toy_epdf}{{2}{14}{\textbf {Per-latent activation profiles for the toy model (layer 2, TopK $K=3$).} Each panel shows the activation of a single SAE latent as a function of the ground-truth belief state (heatmap over Mess3 $(x, a)$ parameter space). Latents are sorted by total activation weight. Individual latents fire preferentially near specific vertices or edges of the belief simplex, tiling the simplex geometry in a graded, partially overlapping fashion. \relax }{figure.caption.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Overview of the belief geometry discovery pipeline.} Text sequences are processed through Gemma-2-9B; residual stream activations at layer 20 are encoded by a TopK SAE. Latent decoder directions are partitioned by k-subspace clustering, and candidate $K\!=\!3$ clusters are fit with AANet to recover barycentric (simplex) coordinates. The resulting cluster representations are evaluated with four complementary validation measurements. \relax }}{15}{figure.caption.8}\protected@file@percent }
\newlabel{fig:pipeline}{{3}{15}{\textbf {Overview of the belief geometry discovery pipeline.} Text sequences are processed through Gemma-2-9B; residual stream activations at layer 20 are encoded by a TopK SAE. Latent decoder directions are partitioned by k-subspace clustering, and candidate $K\!=\!3$ clusters are fit with AANet to recover barycentric (simplex) coordinates. The resulting cluster representations are evaluated with four complementary validation measurements. \relax }{figure.caption.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Cluster 768\_596: spatial structure.} \emph  {(a)} All 5000 sample positions in barycentric coordinates (ternary plot). Concentration near the three vertices indicates that the model visits near-pure vertex states, not just the simplex interior. \emph  {(b)} Centroid positions of the 6 individual SAE latents in the cluster. Latents partition across the three vertices, with each vertex attracting one or two latents (centroids near the corresponding corner), consistent with vertex-specialized feature coding. \relax }}{16}{figure.caption.23}\protected@file@percent }
\newlabel{fig:cluster_596_spatial}{{4}{16}{\textbf {Cluster 768\_596: spatial structure.} \emph {(a)} All 5000 sample positions in barycentric coordinates (ternary plot). Concentration near the three vertices indicates that the model visits near-pure vertex states, not just the simplex interior. \emph {(b)} Centroid positions of the 6 individual SAE latents in the cluster. Latents partition across the three vertices, with each vertex attracting one or two latents (centroids near the corresponding corner), consistent with vertex-specialized feature coding. \relax }{figure.caption.23}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Cluster 768\_140: spatial structure and KL divergence.} \emph  {(a)} Sample scatter in barycentric coordinates. \emph  {(b)} Pairwise symmetric KL divergence distributions for same-vertex (blue), cross-vertex (red), and within-simplex (gray) pairs. The cross-vertex distribution is shifted to substantially higher values, with a cross/same mean ratio of 1.99---by far the strongest KL signal in our dataset. This indicates that tokens near different simplex vertices predict markedly different next-token distributions. \relax }}{16}{figure.caption.24}\protected@file@percent }
\newlabel{fig:cluster_140}{{5}{16}{\textbf {Cluster 768\_140: spatial structure and KL divergence.} \emph {(a)} Sample scatter in barycentric coordinates. \emph {(b)} Pairwise symmetric KL divergence distributions for same-vertex (blue), cross-vertex (red), and within-simplex (gray) pairs. The cross-vertex distribution is shifted to substantially higher values, with a cross/same mean ratio of 1.99---by far the strongest KL signal in our dataset. This indicates that tokens near different simplex vertices predict markedly different next-token distributions. \relax }{figure.caption.24}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Cluster 512\_17: latent decomposition.} \emph  {(a)} Fraction of total cluster activation contributed by each latent at each of the three vertices. Different latents dominate at each vertex, consistent with vertex-specialized feature encoding. \emph  {(b)} Centroid positions of the 15 SAE latents. Clear separation across the three simplex vertices confirms that the cluster's latents have distinct vertex preferences. \relax }}{17}{figure.caption.25}\protected@file@percent }
\newlabel{fig:cluster_17}{{6}{17}{\textbf {Cluster 512\_17: latent decomposition.} \emph {(a)} Fraction of total cluster activation contributed by each latent at each of the three vertices. Different latents dominate at each vertex, consistent with vertex-specialized feature encoding. \emph {(b)} Centroid positions of the 15 SAE latents. Clear separation across the three simplex vertices confirms that the cluster's latents have distinct vertex preferences. \relax }{figure.caption.25}{}}
